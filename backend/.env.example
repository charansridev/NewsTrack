# NewsTrack backend configuration
# Copy to .env and adjust for your environment.

# PostgreSQL connection (psycopg 3 driver)
DATABASE_URL=postgresql+psycopg://vikram@/newstrack

# Two INDEPENDENT JWT secrets — platform users vs drivers.
USER_JWT_SECRET=dev-user-secret-change-me-0123456789abcdef
DRIVER_JWT_SECRET=dev-driver-secret-change-me-0123456789abcdef
JWT_ALGORITHM=HS256

# Access-token lifetimes (seconds)
USER_ACCESS_TOKEN_TTL=3600
DRIVER_ACCESS_TOKEN_TTL=3600
USER_REFRESH_TOKEN_TTL=604800

# Background-job thresholds (minutes)
STALE_STATUS_THRESHOLD_MIN=60
MISSED_DELIVERY_GRACE_MIN=30

# CORS — comma-separated origins allowed to call the API from a browser.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
